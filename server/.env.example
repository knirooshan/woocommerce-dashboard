# .env.example
# Auto-generated by env-compose. Do not edit manually.
# Run: npx env-compose generate

# ---- Required ----
# string | Central MongoDB connection string | secret
CENTRAL_DB_URI=
# string | Default tenant slug
DEFAULT_TENANT_ID=
# string | JWT signing secret — must be at least 16 characters | secret
JWT_SECRET=

# ---- Optional ----
# port (1-65535) | HTTP server port
PORT=5000
# enum: development | production | test
NODE_ENV=development
# string | Tenant MongoDB connection string (use MONGO_URI_BASE in production) | secret
MONGO_URI=
# string | Optional base URI for multi-tenant DB connections | secret
MONGO_URI_BASE=
# url (http/https) | WooCommerce store base URL (stored per-tenant in DB for multi-tenant)
WOO_URL=
# string | WooCommerce REST API consumer key (stored per-tenant in DB) | secret
WOO_CONSUMER_KEY=
# string | WooCommerce REST API consumer secret (stored per-tenant in DB) | secret
WOO_CONSUMER_SECRET=
