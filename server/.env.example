# HTTP server port
PORT=5000

# MongoDB connection string for the default tenant database
MONGO_URI=mongodb://localhost:27017/tenant_<subdomain>

# MongoDB connection string for the central (multi-tenant) database
CENTRAL_DB_URI=mongodb://localhost:27017/merchpilot_central

# Optional: base URI override for constructing tenant DB connections
# MONGO_URI_BASE=mongodb://localhost:27017

# Default tenant subdomain (used in local/single-tenant dev)
DEFAULT_TENANT_ID=ccc

# Secret key used to sign JWT tokens — must be at least 16 characters
JWT_SECRET=change-me-use-a-long-random-secret

# WooCommerce store URL and REST API credentials
WOO_URL=https://your-store.example.com
WOO_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WOO_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Application environment: development | production | test
NODE_ENV=development
